# =============================================================================
# Bricks — local development environment variables
# Copy to .env.local and fill in the values.
#
# Local Supabase values are printed by `supabase start`.
# Run `supabase start` first, then copy the relevant lines below.
# =============================================================================

# ─── Supabase (local) ────────────────────────────────────────────────────────
# Printed by `supabase start` as "API URL" and "anon key" / "service_role key"
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste anon key from `supabase start` output>
SUPABASE_SERVICE_ROLE_KEY=<paste service_role key from `supabase start` output>

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Required for AI features (compliance checks, suggestions, document generation).
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Required for semantic search embeddings (text-embedding-3-small).
# If not set, keyword search still works; semantic search is skipped silently.
# Get from: https://platform.openai.com
OPENAI_API_KEY=<your-openai-api-key>

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Optional for local dev — email sending is skipped silently if not set.
# In-app notifications always work regardless.
# Get from: https://resend.com/api-keys
RESEND_API_KEY=<your-resend-api-key>
EMAIL_FROM=Bricks <notifications@bricks.app>

# ─── Webhook encryption ───────────────────────────────────────────────────────
# Required to create integrations. Generate a 32-byte key with:
#   openssl rand -hex 32
WEBHOOK_ENCRYPTION_KEY=<64-hex-char-string>

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
